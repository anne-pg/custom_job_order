<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="purchase_order_form_inherit_job" model="ir.ui.view">
        <name>purchase.order.form.inherit.job</name>
        <model>purchase.order</model>
        <inherit_id ref="purchase.purchase_order_form"/>
        <arch type="xml">
            <xpath expr="//field[@name='state']" position="attributes">
                <attribute name="statusbar_visible">draft,sent,purchase,job</attribute>
            </xpath>
        </arch>
    </record>
</odoo>
